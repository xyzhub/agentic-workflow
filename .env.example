# Owner channel (§12) — the private DM the workflow uses to message you.
SLACK_BOT_TOKEN=
SLACK_OWNER_ID=
SLACK_OWNER_DM=

# Publishing channels (§14) — outward posting via /publish. Names only here;
# real values live in your env or an uncommitted .env, never committed.
# Only the channels you run need to be set (see /publish connect).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=
MASTODON_ACCESS_TOKEN=
BLUESKY_APP_PASSWORD=
DEVTO_API_KEY=
MEDIUM_INTEGRATION_TOKEN=
HASHNODE_TOKEN=
BUTTONDOWN_TOKEN=
MAILCHIMP_API_KEY=
